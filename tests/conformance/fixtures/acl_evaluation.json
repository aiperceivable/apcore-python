{
  "description": "ACL rule evaluation (first-match-wins, spec §6)",
  "test_cases": [
    {
      "id": "allow_rule_match",
      "rules": [
        {"callers": ["admin"], "targets": ["*"], "effect": "allow"}
      ],
      "default_effect": "deny",
      "caller_id": "admin",
      "target_id": "auth.login",
      "expected": true
    },
    {
      "id": "deny_rule_match",
      "rules": [
        {"callers": ["*"], "targets": ["admin.*"], "effect": "deny"}
      ],
      "default_effect": "allow",
      "caller_id": "user",
      "target_id": "admin.delete",
      "expected": false
    },
    {
      "id": "first_match_wins",
      "rules": [
        {"callers": ["admin"], "targets": ["*"], "effect": "allow"},
        {"callers": ["admin"], "targets": ["*"], "effect": "deny"}
      ],
      "default_effect": "deny",
      "caller_id": "admin",
      "target_id": "anything",
      "expected": true
    },
    {
      "id": "default_deny",
      "rules": [
        {"callers": ["admin"], "targets": ["*"], "effect": "allow"}
      ],
      "default_effect": "deny",
      "caller_id": "user",
      "target_id": "auth.login",
      "expected": false
    },
    {
      "id": "default_allow",
      "rules": [],
      "default_effect": "allow",
      "caller_id": "anyone",
      "target_id": "anything",
      "expected": true
    },
    {
      "id": "null_caller_becomes_external",
      "rules": [
        {"callers": ["@external"], "targets": ["public.*"], "effect": "allow"}
      ],
      "default_effect": "deny",
      "caller_id": null,
      "target_id": "public.api",
      "expected": true
    },
    {
      "id": "multiple_caller_patterns_or",
      "rules": [
        {"callers": ["admin", "moderator"], "targets": ["*"], "effect": "allow"}
      ],
      "default_effect": "deny",
      "caller_id": "moderator",
      "target_id": "posts.delete",
      "expected": true
    },
    {
      "id": "wildcard_target_pattern",
      "rules": [
        {"callers": ["*"], "targets": ["public.*"], "effect": "allow"}
      ],
      "default_effect": "deny",
      "caller_id": "anonymous",
      "target_id": "public.health",
      "expected": true
    },
    {
      "id": "compound_or_in_callers",
      "description": "$or as first element in callers array — matches if any subsequent pattern matches",
      "rules": [
        {
          "callers": ["$or", "admin", "moderator"],
          "targets": ["*"],
          "effect": "allow"
        }
      ],
      "default_effect": "deny",
      "caller_id": "moderator",
      "target_id": "any",
      "expected": true
    },
    {
      "id": "compound_not_in_callers",
      "description": "$not as first element in callers array — matches if subsequent pattern does NOT match",
      "rules": [
        {
          "callers": ["$not", "banned_user"],
          "targets": ["*"],
          "effect": "allow"
        }
      ],
      "default_effect": "deny",
      "caller_id": "good_user",
      "target_id": "any",
      "expected": true
    },
    {
      "id": "condition_roles_match",
      "description": "conditions.roles (list) — at least one role must overlap with identity roles",
      "rules": [
        {
          "callers": ["*"],
          "targets": ["*"],
          "effect": "allow",
          "conditions": {
            "roles": ["editor"]
          }
        }
      ],
      "default_effect": "deny",
      "caller_id": "user_123",
      "caller_identity": {"type": "user", "roles": ["editor", "viewer"]},
      "target_id": "posts.edit",
      "expected": true
    },
    {
      "id": "condition_roles_mismatch",
      "description": "conditions.roles — no overlap with identity roles",
      "rules": [
        {
          "callers": ["*"],
          "targets": ["*"],
          "effect": "allow",
          "conditions": {
            "roles": ["admin"]
          }
        }
      ],
      "default_effect": "deny",
      "caller_id": "user_123",
      "caller_identity": {"type": "user", "roles": ["viewer"]},
      "target_id": "posts.delete",
      "expected": false
    },
    {
      "id": "condition_identity_types_match",
      "description": "conditions.identity_types (list) — identity type must be in allowed list",
      "rules": [
        {
          "callers": ["*"],
          "targets": ["*"],
          "effect": "allow",
          "conditions": {
            "identity_types": ["service"]
          }
        }
      ],
      "default_effect": "deny",
      "caller_id": "service_abc",
      "caller_identity": {"type": "service"},
      "target_id": "internal.sync",
      "expected": true
    },
    {
      "id": "condition_max_call_depth_match",
      "description": "conditions.max_call_depth (integer) — call depth must not exceed threshold",
      "rules": [
        {
          "callers": ["*"],
          "targets": ["*"],
          "effect": "allow",
          "conditions": {
            "max_call_depth": 2
          }
        }
      ],
      "default_effect": "deny",
      "caller_id": "mod_a",
      "call_depth": 1,
      "target_id": "mod_b",
      "expected": true
    },
    {
      "id": "condition_max_call_depth_exceeded",
      "description": "conditions.max_call_depth — call depth exceeds threshold",
      "rules": [
        {
          "callers": ["*"],
          "targets": ["*"],
          "effect": "allow",
          "conditions": {
            "max_call_depth": 1
          }
        }
      ],
      "default_effect": "deny",
      "caller_id": "mod_b",
      "call_depth": 2,
      "target_id": "mod_c",
      "expected": false
    },
    {
      "id": "empty_callers_matches_none",
      "description": "Empty callers array never matches any caller",
      "rules": [
        {"callers": [], "targets": ["*"], "effect": "allow"}
      ],
      "default_effect": "deny",
      "caller_id": "anyone",
      "target_id": "anything",
      "expected": false
    },
    {
      "id": "empty_targets_matches_none",
      "description": "Empty targets array never matches any target",
      "rules": [
        {"callers": ["*"], "targets": [], "effect": "allow"}
      ],
      "default_effect": "deny",
      "caller_id": "anyone",
      "target_id": "anything",
      "expected": false
    },
    {
      "id": "at_system_pattern",
      "description": "@system matches calls where identity type is system",
      "rules": [
        {"callers": ["@system"], "targets": ["*"], "effect": "allow"}
      ],
      "default_effect": "deny",
      "caller_id": "system.health",
      "caller_identity": {"type": "system"},
      "target_id": "internal.check",
      "expected": true
    },
    {
      "id": "conditions_without_context_denies",
      "description": "Conditions present but no context provided — rule does not match",
      "rules": [
        {
          "callers": ["*"],
          "targets": ["*"],
          "effect": "allow",
          "conditions": {
            "roles": ["admin"]
          }
        }
      ],
      "default_effect": "deny",
      "caller_id": "user_123",
      "caller_identity": null,
      "target_id": "admin.panel",
      "expected": false
    },
    {
      "id": "condition_or_compound",
      "description": "$or in conditions — matches if any sub-condition set passes",
      "rules": [
        {
          "callers": ["*"],
          "targets": ["*"],
          "effect": "allow",
          "conditions": {
            "$or": [
              {"roles": ["admin"]},
              {"identity_types": ["system"]}
            ]
          }
        }
      ],
      "default_effect": "deny",
      "caller_id": "sys_agent",
      "caller_identity": {"type": "system", "roles": []},
      "target_id": "admin.panel",
      "expected": true
    },
    {
      "id": "condition_not_compound",
      "description": "$not in conditions — matches if sub-condition set fails",
      "rules": [
        {
          "callers": ["*"],
          "targets": ["*"],
          "effect": "allow",
          "conditions": {
            "$not": {
              "identity_types": ["anonymous"]
            }
          }
        }
      ],
      "default_effect": "deny",
      "caller_id": "user_123",
      "caller_identity": {"type": "user", "roles": []},
      "target_id": "protected.resource",
      "expected": true
    }
  ]
}
